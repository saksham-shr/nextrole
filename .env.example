# ── Supabase ───────────────────────────────────────────────────────────────────
# Project URL and keys from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
ADMIN_EMAIL=your@email.com

# Encryption key for sensitive stored data (32-byte hex)
PROVIDER_ENCRYPTION_KEY=

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Optional additional providers
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Lemon Squeezy ──────────────────────────────────────────────────────────────
# Webhook signing secret — Settings → Webhooks → your endpoint → Signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=

# API key — Settings → API → Create API key
LEMONSQUEEZY_API_KEY=

# Subscription product checkout URLs (one per product, variants selected via ?variant=)
# Products → [Product] → Share → Copy checkout link
NEXT_PUBLIC_LS_STARTER_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
NEXT_PUBLIC_LS_PRO_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...

# Top-up credit pack product checkout URL
NEXT_PUBLIC_LS_TOPUP_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...

# Variant IDs — Products → [Product] → Variants → click variant → ID in URL
# Used by the webhook to identify which tier/pack to activate
NEXT_PUBLIC_LS_STARTER_MONTHLY_ID=
NEXT_PUBLIC_LS_STARTER_YEARLY_ID=
NEXT_PUBLIC_LS_PRO_MONTHLY_ID=
NEXT_PUBLIC_LS_PRO_YEARLY_ID=

LEMONSQUEEZY_VARIANT_STARTER_MONTHLY=
LEMONSQUEEZY_VARIANT_STARTER_YEARLY=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
LEMONSQUEEZY_VARIANT_PRO_YEARLY=

LEMONSQUEEZY_VARIANT_TOPUP_MINI=
LEMONSQUEEZY_VARIANT_TOPUP_SMALL=
LEMONSQUEEZY_VARIANT_TOPUP_MEDIUM=
LEMONSQUEEZY_VARIANT_TOPUP_LARGE=

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
TRIAL_EMAIL_FROM=NextRole <billing@yourdomain.com>

# ── Cron ───────────────────────────────────────────────────────────────────────
# Secret used to authenticate the nightly credit-reset cron endpoint
CRON_SECRET=
