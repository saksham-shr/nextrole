# ── Supabase ───────────────────────────────────────────────────────────────────
# Project URL and keys — Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
ADMIN_EMAIL=your@email.com

# Encryption key for sensitive stored data (generate: openssl rand -hex 32)
PROVIDER_ENCRYPTION_KEY=

# ── AI ─────────────────────────────────────────────────────────────────────────
# Primary provider — at least one is required
OPENROUTER_API_KEY=sk-or-v1-...

# Optional direct-provider fallbacks (used only when OPENROUTER_API_KEY is unset)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Razorpay ───────────────────────────────────────────────────────────────────
# Dashboard → Settings → API Keys
# Test keys start with rzp_test_, live keys with rzp_live_
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Same key exposed to the frontend (used in Razorpay Checkout JS)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Webhook signing secret — Dashboard → Settings → Webhooks → your endpoint → Signing secret
# Register URL: https://yourdomain.com/api/webhooks/razorpay
# Enable events: payment.captured, payment.failed,
#                subscription.cancelled, subscription.completed, subscription.halted
RAZORPAY_WEBHOOK_SECRET=

# ── Cron ───────────────────────────────────────────────────────────────────────
# Random secret to authenticate the nightly credit-reset endpoint.
# Generate: openssl rand -hex 32
# Must match the Authorization header in your Vercel / cron runner config.
CRON_SECRET=

# ── Rate limiting (optional) ───────────────────────────────────────────────────
# Falls back to in-memory per-process limiter when unset (fine for dev/low traffic).
# For production: provision an Upstash Redis database and paste credentials here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Email (optional) ───────────────────────────────────────────────────────────
# Used for trial expiry notifications and transactional emails.
# Resend: https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=
TRIAL_EMAIL_FROM=NextRole <billing@yourdomain.com>
